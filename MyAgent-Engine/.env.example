ENVIRONMENT=development
APP_NAME=MyAgent Community Edition
APP_VERSION=3.0.0
API_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
AUTO_CREATE_TABLES=true
SEED_DEMO_USER=false
ENABLE_LEGACY_ROUTES=false
SECRET_KEY=dev-only-secret-key-32-characters-minimum
JWT_SECRET=dev-only-jwt-secret-32-characters-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_REQUESTS=120
AUTH_RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=3145728
DATABASE_URL=sqlite+aiosqlite:///./myagent.db
DEFAULT_PROVIDER=mock
PROVIDER_FALLBACKS=mock
PROVIDER_TIMEOUT_SECONDS=60
PROVIDER_RETRY_COUNT=2
PROVIDER_RETRY_BASE_SECONDS=0.25
PROVIDER_TRUST_ENVIRONMENT_PROXY=false
PROVIDER_PRICING_JSON={}
CONTEXT_MESSAGE_LIMIT=30
CONTEXT_CHARACTER_LIMIT=60000
CONVERSATION_SUMMARY_TRIGGER=40
CONVERSATION_SUMMARY_MAX_CHARS=4000
KNOWLEDGE_RESULT_LIMIT=4
KNOWLEDGE_EXCERPT_CHARS=1800
SYSTEM_PROMPT=You are MyAgent, a secure, accurate and helpful AI assistant.
FEATURE_TOOLS=true
FEATURE_RAG=false

# Optional enterprise extension flags remain false in Community Edition.
FEATURE_REDIS=false
FEATURE_QDRANT=false
FEATURE_MARKETPLACE=false
FEATURE_ANALYTICS=false
FEATURE_WORKERS=false
FEATURE_QUEUES=false
FEATURE_BACKGROUND_TASKS=false
FEATURE_METRICS=false
FEATURE_MONITORING=false
FEATURE_CLUSTERING=false
FEATURE_ENTERPRISE_PROVIDERS=false

# Provider credentials are optional; the mock provider works without keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1
ZAI_API_KEY=
ZAI_MODEL=glm-4.5-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
