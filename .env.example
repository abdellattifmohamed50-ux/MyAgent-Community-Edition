# MyAgent Community Edition v3.0 — Docker Compose defaults to SQLite.
ENVIRONMENT=development
SECRET_KEY=local-community-secret-change-before-production
JWT_SECRET=local-community-jwt-secret-change-before-production
CORS_ORIGINS=http://localhost:8080
TRUSTED_HOSTS=localhost,127.0.0.1,engine,web
DEFAULT_PROVIDER=mock
PROVIDER_FALLBACKS=mock
FEATURE_TOOLS=true
FEATURE_RAG=false

# Add only providers you use. Never commit real keys.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
ZAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
